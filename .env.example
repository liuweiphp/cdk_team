# MySQL root 密码 —— docker-compose 用它创建 MySQL 容器并拼接 backend 的 DB_DSN
DB_ROOT_PASSWORD=changeme

# 本地直跑 backend 时用的连接串(走 docker compose 时由 compose 覆盖,不读这一行)
DB_DSN=root:changeme@tcp(localhost:3306)/exchange_cdk?charset=utf8mb4&parseTime=True&loc=Local
JWT_SECRET=change-me-to-a-random-secret-string
SERVER_PORT=8080
LOG_LEVEL=debug
BCRYPT_COST=12
MAX_EXCHANGE_QUANTITY=50
